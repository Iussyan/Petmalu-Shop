[gd_scene format=3 uid="uid://cxo4nn3xkcf0f"]

[sub_resource type="GDScript" id="GDScript_dialogue"]
script/source = "extends CanvasLayer

@onready var name_lbl = $Panel/VBox/Header/Name
@onready var role_lbl = $Panel/VBox/Header/Role
@onready var content_lbl = $Panel/VBox/Content

var npc_owner: Node = null

func _ready():
	# Simple entrance animation
	$Panel.pivot_offset = $Panel.get_rect().size / 2
	var tween = create_tween().set_parallel(true).set_trans(Tween.TRANS_BACK).set_ease(Tween.EASE_OUT)
	tween.tween_property($Panel, \"scale\", Vector2.ONE, 0.3).from(Vector2(0.9, 0.9))
	tween.tween_property($Panel, \"modulate:a\", 1.0, 0.2).from(0.0)
	
	# Pulsing hint
	var hint = $Panel/VBox/Hint
	var pulse = create_tween().set_loops().set_trans(Tween.TRANS_SINE)
	pulse.tween_property(hint, \"modulate:a\", 0.4, 1.0)
	pulse.tween_property(hint, \"modulate:a\", 1.0, 1.0)

func setup(name_text: String, role_text: String, content: String):
	name_lbl.text = name_text
	role_lbl.text = role_text
	content_lbl.text = content
"

