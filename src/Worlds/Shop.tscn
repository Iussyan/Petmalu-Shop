[sub_resource type="GDScript" id="GDScript_shop"]
script/source = "extends Node2D

func _ready():
	# Modular Teleport Placement
	if GameManager.target_entrance_id != -1:
		_position_player_at_entrance(GameManager.target_entrance_id)
		GameManager.target_entrance_id = -1
		
	if has_node(\"/root/FadeOverlay\"):
		get_node(\"/root/FadeOverlay\").fade_in()
	
	# Update Shop Evolution
	_update_shop_evolution()
	
	# Spawn pets that are in the shop
	for pet_data in GameManager.rescued_pets_data:
		_spawn_pet(pet_data)

func _position_player_at_entrance(id):
	for node in get_tree().get_nodes_in_group(\"entrances\"):
		if \"my_id\" in node and node.my_id == id:
			$Player.global_position = node.global_position + node.spawn_offset
			$Player.set_facing_direction(GameManager.player_facing_on_spawn)
			return

func _spawn_pet(data):
	var pet_scene = load(\"res://src/Pets/BasePet.tscn\")
	var pet = pet_scene.instantiate()
	pet.pet_type = data.type
	pet.pet_custom_name = data.get(\"custom_name\", \"\")
	pet.wild_behavior = data.get(\"wild_behavior\", 0)
	pet.shop_behavior = data.get(\"shop_behavior\", 1) # Default to Loyal in shop
	pet.current_state = 1 # SHOP state
	pet.hunger = data.hunger
	pet.health = data.health
	pet.happiness = data.happiness
	
	# Persistence Logic - Restore position if it exists
	if data.has(\"position\"):
		pet.global_position = data.position
	else:
		pet.position = Vector2(randf_range(-200, 200), randf_range(-100, 100))
		
	$PetSanctuary/Pets.add_child(pet)

func _notification(what):
	if what == NOTIFICATION_EXIT_TREE:
		_save_shop_pets()

func _save_shop_pets():
	var new_data = []
	var pets_container = get_node_or_null(\"PetSanctuary/Pets\")
	if pets_container:
		for pet in pets_container.get_children():
			if pet.has_method(\"get_stats_data\"):
				new_data.append(pet.get_stats_data())
		GameManager.rescued_pets_data = new_data

func _update_shop_evolution():
	var lvl = GameManager.shop_level
	if has_node(\"Nursery\"): $Nursery.visible = lvl >= 2
	if has_node(\"Clinic\"): $Clinic.visible = lvl >= 3
	if has_node(\"Garden\"): $Garden.visible = lvl >= 4
"

