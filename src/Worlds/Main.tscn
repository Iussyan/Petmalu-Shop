[sub_resource type="GDScript" id="GDScript_main"]
script/source = "extends Node2D

@onready var desert_lock = get_node_or_null(\"%DesertLock\")
@onready var forest_lock = get_node_or_null(\"%ForestLock\")
@onready var beach_lock = get_node_or_null(\"%BeachLock\")

func _ready():
	# Modular Teleport Placement
	if GameManager.target_entrance_id != -1:
		_position_player_at_entrance(GameManager.target_entrance_id)
		GameManager.target_entrance_id = -1 # Clear it
		
	# BGM Setup
	if has_node(\"/root/AudioManager\"):
		AudioManager.play_bgm(\"res://assets/Audio/BGM/town_theme.mp3\")
	
	if has_node(\"/root/FadeOverlay\"):
		get_node(\"/root/FadeOverlay\").fade_in()
		
	if GameManager.has_signal(\"area_unlocked\"):
		GameManager.area_unlocked.connect(_on_area_unlocked)
	
	# Initial visibility
	if desert_lock: desert_lock.visible = !GameManager.is_area_unlocked(\"Desert\")
	if forest_lock: forest_lock.visible = !GameManager.is_area_unlocked(\"Forest\")
	if beach_lock: beach_lock.visible = !GameManager.is_area_unlocked(\"Beach\")
	
	_setup_camera_bounds()

func _setup_camera_bounds():
	var town_bounds = get_node_or_null(\"World/TownCameraBounds\")
	var player_node = get_node_or_null(\"Player\")
	
	if town_bounds and player_node:
		var player_camera = player_node.get_node_or_null(\"Camera2D\")
		if player_camera:
			town_bounds.visible = false
			var rect = town_bounds.get_global_rect()
			player_camera.limit_left = int(rect.position.x)
			player_camera.limit_top = int(rect.position.y)
			player_camera.limit_right = int(rect.end.x)
			player_camera.limit_bottom = int(rect.end.y)
			player_camera.limit_smoothed = true

func _position_player_at_entrance(id):
	# Find all Entrance nodes in the world
	for node in get_tree().get_nodes_in_group(\"entrances\"):
		if \"my_id\" in node and node.my_id == id:
			$Player.global_position = node.global_position + node.spawn_offset
			$Player.set_facing_direction(GameManager.player_facing_on_spawn)
			return

func _on_area_unlocked(area_name):
	match area_name:
		\"Desert\": if desert_lock: desert_lock.visible = false
		\"Forest\": if forest_lock: forest_lock.visible = false
		\"Beach\": if beach_lock: beach_lock.visible = false
"

