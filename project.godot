; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Petmalu Shop"
run/main_scene="res://src/UI/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://src/Autoloads/GameManager.gd"
FadeOverlay="*res://src/UI/FadeOverlay.tscn"
MainHUD="*res://src/UI/MainHUD.tscn"
ItemDB="*res://src/Autoloads/ItemDB.gd"
SaveManager="*res://src/Autoloads/SaveManager.gd"
AudioManager="*res://src/Autoloads/AudioManager.gd"

[display]

window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[editor]

import/use_multiple_threads=false

[editor_plugins]

enabled=PackedStringArray("res://addons/sprite_cutter/plugin.cfg")

[file_customization]

folder_colors={
"res://Tilesets/": "teal",
"res://assets/": "yellow",
"res://src/": "green"
}

[gui]

theme/default_font_multichannel_signed_distance_field=true

[layer_names]

2d_physics/layer_1="Ground"
2d_physics/layer_2="Player"
2d_physics/layer_3="Interactable"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
